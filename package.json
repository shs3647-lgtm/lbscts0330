{
  "name": "fmea-onpremise",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "dev:4000": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev -p 4000",
    "dev:5000": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev -p 5000",
    "dev:light": "cross-env DEV_LIGHT=1 NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "dev:full": "cross-env NODE_OPTIONS=--max-old-space-size=4096 next dev",
    "modules": "node scripts/toggle-modules.js status",
    "modules:off": "node scripts/toggle-modules.js disable all",
    "modules:on": "node scripts/toggle-modules.js enable all",
    "build": "next build",
    "start": "next start",
    "start:4000": "next start -p 4000",
    "lint": "eslint",
    "prepare": "simple-git-hooks",
    "guard:protected:staged": "tsx scripts/guard/protected-paths.ts --mode staged",
    "guard:protected:branch": "tsx scripts/guard/protected-paths.ts --mode branch",
    "guard:protected:commitmsg": "tsx scripts/guard/commit-msg-approval.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "dotenv -- npx tsx scripts/seed-base-data.ts",
    "db:seed:lld": "dotenv -- npx tsx scripts/seed-lld-data.mjs",
    "db:seed:fmea": "dotenv -- npx tsx scripts/seed-m002.ts",
    "db:seed:all": "npm run db:seed && npm run db:seed:lld",
    "migrate:public-cp-pfd-to-project": "dotenv -- npx tsx scripts/migrate-public-cp-pfd-to-project-schema.ts",
    "migrate:public-cp-pfd-to-project:dry": "dotenv -- npx tsx scripts/migrate-public-cp-pfd-to-project-schema.ts --dry-run",
    "verify:pipeline-baseline": "npx tsx scripts/verify-location-fk-baseline.ts",
    "verify:pipeline-baseline:strict": "npx tsx scripts/verify-location-fk-baseline.ts --baseline",
    "verify:import-fe-layout": "npx tsx scripts/verify-import-fe-chain-layout.ts",
    "diag:pipeline-fk": "npx tsx scripts/diag-pipeline-fk-compare.ts",
    "verify:all": "npx tsx scripts/verify-all.ts",
    "audit:sidebar-routes": "npx tsx scripts/audit-fmea-sidebar-routes.ts",
    "release:audit": "npm run audit:sidebar-routes && npx tsc --noEmit",
    "export:validation-excel": "npx tsx scripts/export-fmea-validation-excel.ts",
    "fill:excel-forward": "npx tsx scripts/fill-excel-forward-fill.ts",
    "forge:m100": "powershell -NoProfile -ExecutionPolicy Bypass -File m100/scripts/forge-m100-loop.ps1",
    "test": "vitest",
    "test:run": "vitest run",
    "test:import-slice": "vitest run tests/guard/save-position-import-fk.guard.test.ts tests/guard/position-format-routing.guard.test.ts tests/position-import/position-parser.test.ts tests/import/atomic-to-flat-c1c4-fk.test.ts tests/import/position-parse-statistics.test.ts",
    "test:coverage": "vitest run --coverage",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "docker:clean": "docker-compose down -v --remove-orphans",
    "db:purge": "node scripts/purge-expired-soft-deletes.js",
    "db:purge:dry": "cross-env DRY_RUN=true node scripts/purge-expired-soft-deletes.js",
    "snapshot": "node scripts/create-snapshot.js",
    "snapshot:list": "node -e \"const fs=require('fs');const p=require('path');const d='snapshots';if(fs.existsSync(d)){fs.readdirSync(d).filter(f=>fs.statSync(p.join(d,f)).isDirectory()).reverse().forEach((f,i)=>console.log((i+1)+'. '+f))}else{console.log('No snapshots found')}\"",
    "guard:raw-to-atomic": "tsx scripts/guard/check-raw-to-atomic-fields.ts",
    "guard:invariants": "tsx scripts/guard/check-invariants.ts",
    "test:e2e:final": "playwright test tests/e2e/sidebar-fmea-core-routes-smoke.spec.ts tests/e2e/worksheet-failure-tabs-smoke.spec.ts --project=chromium",
    "test:e2e:final-headed": "playwright test tests/e2e/sidebar-fmea-core-routes-smoke.spec.ts tests/e2e/worksheet-failure-tabs-smoke.spec.ts --project=chromium --headed"
  },
  "simple-git-hooks": {
    "pre-commit": "npm run guard:invariants -- --warn-only && npm run guard:protected:staged -- --warn-only && npm run guard:raw-to-atomic",
    "commit-msg": "npm run guard:protected:commitmsg --",
    "pre-push": "npm run guard:protected:branch"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.18",
    "@tanstack/react-virtual": "^3.13.21",
    "@types/bcryptjs": "^2.4.6",
    "bcryptjs": "^3.0.3",
    "chart.js": "^4.5.1",
    "chartjs-plugin-datalabels": "^2.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "file-saver": "^2.0.5",
    "gantt-task-react": "^0.3.9",
    "html2canvas-pro": "^1.6.7",
    "jspdf": "^4.1.0",
    "lucide-react": "^0.562.0",
    "next": "16.1.1",
    "nodemailer": "^7.0.12",
    "pg": "^8.16.3",
    "prisma": "^7.2.0",
    "react": "19.2.3",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "19.2.3",
    "react-pdf": "^10.3.0",
    "recharts": "^3.7.0",
    "resend": "^6.8.0",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/file-saver": "^2.0.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.5",
    "@types/pg": "^8.16.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.17",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "jest": "^30.2.0",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "playwright": "^1.57.0",
    "puppeteer": "^24.37.5",
    "simple-git-hooks": "^2.13.1",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.6",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.17"
  }
}
