model ImportAtomMap {
  id              String   @id @default(uuid())
  fmeaId          String
  elementId       String   // 워크시트 데이터의 실제 ID (ex: id_1f29a3c15ea108_19)
  elementType     String   // l1 | l2 | l3 | l1func | l2func | l3func | fe | fm | fc | processChar | specialChar
  name            String   @default("")   // 요소명/값
  parentElementId String?  // 부모 요소 ID (ex: L3의 부모 = L2 ID)
  grandParentId   String?  // 조부모 요소 ID (ex: L3의 조부모 = L1 ID)
  excelRow        Int?     // Excel 원본 행번호
  excelCol        Int?     // Excel 원본 열번호
  excelSheet      String?  // Excel 시트명
  rowSpan         Int      @default(1)
  colSpan         Int      @default(1)
  mergeGroupId    String?  // 셀 병합 그룹 ID
  sortOrder       Int      @default(0)
  variableName    String?  // 프로그래밍 변수명 (ex: "l2[0].l3[1].functions[0]")
  metadata        Json?    // 추가 메타데이터 (specialChar, confirmed 등)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([fmeaId])
  @@index([elementId])
  @@index([elementType])
  @@index([parentElementId])
  @@map("import_atom_maps")
}

// =====================================================
// SpecialCharMasterItem: 특별특성 마스터 (DB 영속화 + 추천 루프)
