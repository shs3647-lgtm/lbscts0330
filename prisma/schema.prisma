// ============================================================
// LLD(필터코드) 통합 모델
// 기존 LessonsLearned + KrIndustry + Import 마스터 통합
// 정확 매칭: processNo + processName + productName
// 수평전개: 유사제품 LLD를 다른 FMEA에 전개
// ============================================================

model LLDFilterCode {
  id              String   @id @default(uuid())
  lldNo           String   @unique              // LLD26-001 형식

  // -- 분류 --
  classification  String                         // RMA | ABN | CIP | ECN | FieldIssue | DevIssue
  applyTo         String                         // prevention | detection

  // -- 정확 매칭용 필수 필드 --
  processNo       String                         // 공정번호
  processName     String                         // 공정명
  productName     String                         // 제품명 (수평전개 기준)

  // -- 고장 정보 --
  failureMode     String                         // 고장형태
  cause           String                         // 발생원인

  // -- 관리 기준값 --
  severity        Int?                           // 심각도 S값 (1-10)
  occurrence      Int?                           // 발생도 O값 (예방관리 시 필수)
  detection       Int?                           // 검출도 D값 (검출관리 시 필수)
  improvement     String                         // 개선대책 (레거시 호환)
  preventionImprovement String @default("")      // 예방관리 개선
  detectionImprovement  String @default("")      // 검출관리 개선

  // -- 메타 --
  vehicle         String   @default("")          // 차종
  target          String   @default("제조")      // 설계 | 부품 | 제조
  owner           String   @default("")          // 담당자
  attachmentUrl   String?                        // 첨부(근거서류) URL
  m4Category      String?                        // MN | MC | IM | EN
  location        String?                        // 발생장소
  completedDate   String?                        // 완료일자
  status          String   @default("R")         // G=완료 | Y=진행 | R=미완료
  sourceType      String   @default("manual")    // manual | import | industry
  priority        Int      @default(0)           // 추천 우선순위 (높을수록 우선)

  // -- FMEA 적용 추적 --
  fmeaId          String?                        // 적용된 FMEA ID
  appliedDate     String?                        // 적용 날짜

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([processNo, processName])
  @@index([productName])
  @@index([classification])
  @@index([applyTo])
  @@index([status])
  @@index([fmeaId])
  @@map("lld_filter_code")
}

