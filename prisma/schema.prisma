generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model APQPProject {
  id           String   @id @default(uuid())
  name         String
  productName  String
  customerName String
  status       String
  startDate    String?
  targetDate   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("apqp_projects")
}

// =====================================================
// TripletGroup: PFMEA + CP + PFD 세트 관리 (M/F/P 계층)
// =====================================================
model TripletGroup {
  id                String    @id                    // tg26-m001, tg26-f001, tg26-p001
  year              String    @db.Char(2)            // 26
  typeCode          String    @db.Char(1)            // m | f | p
  linkGroup         Int?                             // p타입만 사용 (i{GG})

  pfmeaId           String?                          // pfm26-m001
  cpId              String?                          // cp26-m001 (null = Lazy 미생성)
  pfdId             String?                          // pfd26-m001 (null = Lazy 미생성)

  parentTripletId   String?                          // 상위 TripletGroup ID
  parent            TripletGroup?  @relation("TripletHierarchy", fields: [parentTripletId], references: [id])
  children          TripletGroup[] @relation("TripletHierarchy")

  subject           String?                          // 공통 문서명
  productName       String?                          // 공통 제품명
  revision          String?    @default("Rev.00")    // 공통 개정번호
  partNo            String?                          // 공통 부품번호
  customerName      String?                          // 공통 고객사
  companyName       String?                          // 공통 회사명
  responsibleName   String?                          // 공통 담당자
  processNumber     String?                          // 공통 공정번호

  syncStatus        String     @default("synced")    // synced | pending | conflict
  version           Int        @default(1)           // Optimistic locking

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([typeCode, year])
  @@index([parentTripletId])
  @@index([pfmeaId])
  @@index([cpId])
  @@index([pfdId])
  @@map("triplet_groups")
}

model ProjectLinkage {
  id                    String   @id @default(uuid())
  apqpNo                String?
  pfmeaId               String?
  dfmeaId               String?
  pfdNo                 String?
  cpNo                  String?
  companyName           String?
  engineeringLocation   String?
  customerName          String?
  modelYear             String?
  subject               String?
  partNo                String?
  projectName           String?
  startDate             String?
  revisionDate          String?
  processResponsibility String?
  confidentialityLevel  String?
  responsibleName       String?
  linkType              String   @default("auto")
  status                String   @default("active")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  createdBy             String?

  @@index([apqpNo])
  @@index([pfmeaId])
  @@index([dfmeaId])
  @@index([pfdNo])
  @@index([cpNo])
  @@index([status])
  @@map("project_linkages")
}

model UnifiedProcessItem {
  id               String            @id @default(uuid())
  projectLinkageId String?
  apqpNo           String?
  processNo        String
  processName      String
  processLevel     String?
  processDesc      String?
  partName         String?
  equipment        String?
  equipmentM4      String?            // ★ 4M 원본 코드 보존 (MC/MD/JG/IM/EN)
  workElement      String?
  productChar      String?
  processChar      String?
  specialChar      String?
  fmeaL2Id         String?            // ★ FMEA L2Structure ID 직접 참조
  fmeaL3Id         String?            // ★ FMEA L3Structure ID 직접 참조
  parentId         String?
  mergeGroupId     String?
  rowSpan          Int?              @default(1)
  sortOrder        Int               @default(0)
  isDeleted        Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  controlPlanItems ControlPlanItem[]
  pfdItems         PfdItem[]

  @@index([projectLinkageId])
  @@index([apqpNo])
  @@index([processNo])
  @@index([fmeaL2Id])
  @@index([fmeaL3Id])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("unified_process_items")
}

model L1Structure {
  id           String        @id @default(uuid())
  fmeaId       String
  name         String
  confirmed    Boolean?      @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rowIndex     Int           @default(0)
  colIndex     Int           @default(0)
  parentId     String?
  mergeGroupId String?
  rowSpan      Int?          @default(1)
  colSpan      Int?          @default(1)
  l1Functions    L1Function[]
  l1Requirements L1Requirement[]
  l2Structures   L2Structure[]

  @@index([fmeaId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@index([rowIndex])
  @@map("l1_structures")
}

model L2Structure {
  id           String        @id @default(uuid())
  fmeaId       String
  l1Id         String
  no           String
  name         String
  order        Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  rowIndex     Int           @default(0)
  colIndex     Int           @default(1)
  parentId     String?
  mergeGroupId String?
  rowSpan      Int?          @default(1)
  colSpan      Int?          @default(1)
  failureModes        FailureMode[]
  l2Functions         L2Function[]
  processProductChars ProcessProductChar[]  // ★ 2026-03-14: 제품특성 독립 엔티티
  l1Structure         L1Structure   @relation(fields: [l1Id], references: [id], onDelete: Cascade)
  l3Structures        L3Structure[]

  @@index([fmeaId])
  @@index([l1Id])
  @@index([parentId])
  @@index([mergeGroupId])
  @@index([rowIndex])
  @@map("l2_structures")
}

model L3Structure {
  id            String         @id @default(uuid())
  fmeaId        String
  l1Id          String
  l2Id          String
  m4            String?
  name          String
  order         Int
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  rowIndex      Int            @default(0)
  colIndex      Int            @default(3)
  parentId      String?
  mergeGroupId  String?
  rowSpan       Int?           @default(1)
  colSpan       Int?           @default(1)
  failureCauses FailureCause[]
  l3Functions   L3Function[]
  l2Structure   L2Structure    @relation(fields: [l2Id], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([l1Id])
  @@index([l2Id])
  @@index([parentId])
  @@index([mergeGroupId])
  @@index([rowIndex])
  @@map("l3_structures")
}

model L1Function {
  id              String           @id @default(uuid())
  fmeaId          String
  l1StructId      String
  category        String
  functionName    String
  requirement     String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parentId        String?
  mergeGroupId    String?
  rowSpan         Int?             @default(1)
  colSpan         Int?             @default(1)
  failureEffects  FailureEffect[]
  l1Requirements  L1Requirement[]
  l1Structure     L1Structure      @relation(fields: [l1StructId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([l1StructId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("l1_functions")
}

/// C3 요구사항 전용 원자성 테이블 — 2026-03-17
/// L1Function.requirement(문자열)과 별도로 C3 행 수를 정확히 카운트하기 위해 분리
model L1Requirement {
  id           String      @id
  fmeaId       String
  l1StructId   String
  l1FuncId     String
  requirement  String
  orderIndex   Int         @default(0)
  createdAt    DateTime    @default(now())
  l1Function   L1Function  @relation(fields: [l1FuncId], references: [id], onDelete: Cascade)
  l1Structure  L1Structure @relation(fields: [l1StructId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([l1FuncId])
  @@map("l1_requirements")
}

// ★★★ 2026-03-14: 제품특성 독립 엔티티 (A4 원자성 DB) ★★★
// 이전: L2Function.productChar = String (텍스트), FailureMode.productCharId = String? (관계 없음)
// 수정: ProcessProductChar 독립 테이블 → FM이 FK로 참조 → CP/PFD 공유 가능
model ProcessProductChar {
  id           String        @id @default(uuid())
  fmeaId       String
  l2StructId   String
  name         String                              // A4 값 (제품특성명)
  specialChar  String?                             // 특별특성 기호 (◇, ◆, △, ○ 등)
  orderIndex   Int           @default(0)           // 같은 공정 내 순서
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  l2Structure  L2Structure   @relation(fields: [l2StructId], references: [id], onDelete: Cascade)
  failureModes FailureMode[] @relation("FmProductChar")

  @@index([fmeaId])
  @@index([l2StructId])
  @@map("process_product_chars")
}

model L2Function {
  id           String        @id @default(uuid())
  fmeaId       String
  l2StructId   String
  functionName String
  productChar  String                              // 기존 텍스트 필드 (하위호환)
  specialChar  String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  parentId     String?
  mergeGroupId String?
  rowSpan      Int?          @default(1)
  colSpan      Int?          @default(1)
  failureModes FailureMode[]
  l2Structure  L2Structure   @relation(fields: [l2StructId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([l2StructId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("l2_functions")
}

model L3Function {
  id              String           @id @default(uuid())
  fmeaId          String
  l3StructId      String
  l2StructId      String
  functionName    String
  processChar     String
  specialChar     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  parentId        String?
  mergeGroupId    String?
  rowSpan         Int?             @default(1)
  colSpan         Int?             @default(1)
  failureCauses   FailureCause[]
  l3ProcessChars  L3ProcessChar[]  // ★v4: B3 독립 엔티티
  l3Structure     L3Structure      @relation(fields: [l3StructId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([l3StructId])
  @@index([l2StructId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("l3_functions")
}

// ★v4 신규: B3(공정특성) 독립 엔티티 — L3Function.processChar 문자열에서 분리
model L3ProcessChar {
  id          String     @id
  fmeaId      String
  l3FuncId    String
  l3StructId  String
  parentId    String?
  name        String
  specialChar String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  l3Function  L3Function @relation(fields: [l3FuncId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([l3FuncId])
  @@index([l3StructId])
  @@index([parentId])
  @@map("l3_process_chars")
}

model FailureEffect {
  id           String        @id @default(uuid())
  fmeaId       String
  l1FuncId     String
  category     String
  effect       String
  severity     Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  parentId     String?
  mergeGroupId String?
  rowSpan      Int?          @default(1)
  colSpan      Int?          @default(1)
  l1Function   L1Function    @relation(fields: [l1FuncId], references: [id], onDelete: Cascade)
  failureLinks FailureLink[]

  @@index([fmeaId])
  @@index([l1FuncId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("failure_effects")
}

model FailureMode {
  id            String              @id @default(uuid())
  fmeaId        String
  l2FuncId      String
  l2StructId    String
  productCharId String?
  mode          String
  specialChar   Boolean?            @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  parentId      String?
  mergeGroupId  String?
  rowSpan       Int?                @default(1)
  colSpan       Int?                @default(1)
  failureLinks  FailureLink[]
  l2Function    L2Function          @relation(fields: [l2FuncId], references: [id], onDelete: Cascade)
  l2Structure   L2Structure         @relation(fields: [l2StructId], references: [id], onDelete: Cascade)
  // ★★★ 2026-03-14: ProcessProductChar FK 관계 추가 ★★★
  productChar   ProcessProductChar? @relation("FmProductChar", fields: [productCharId], references: [id], onDelete: Restrict)

  @@index([fmeaId])
  @@index([l2FuncId])
  @@index([l2StructId])
  @@index([productCharId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("failure_modes")
}

model FailureCause {
  id            String        @id @default(uuid())
  fmeaId        String
  l3FuncId      String
  l3StructId    String
  l2StructId    String
  processCharId String?
  cause         String
  occurrence    Int?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  parentId      String?
  mergeGroupId  String?
  rowSpan       Int?          @default(1)
  colSpan       Int?          @default(1)
  l3Function    L3Function    @relation(fields: [l3FuncId], references: [id], onDelete: Cascade)
  l3Structure   L3Structure   @relation(fields: [l3StructId], references: [id], onDelete: Cascade)
  failureLinks  FailureLink[]

  @@index([fmeaId])
  @@index([l3FuncId])
  @@index([l3StructId])
  @@index([l2StructId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@map("failure_causes")
}

// ★★★ 2026-02-16: 1 FMEA = 1 Dataset 독립 아키텍처 ★★★
model PfmeaMasterDataset {
  id             String                @id @default(uuid())
  name           String
  fmeaId         String                @unique  // ★ 1 FMEA = 1 Dataset
  fmeaType       String                         // M | F | P
  parentFmeaId   String?                        // 상위 FMEA 연결
  sourceFmeaId   String?                        // ★ 연동 원본 FMEA ID (어디서 가져왔는지)
  isActive       Boolean               @default(true)
  version        Int                    @default(1)
  relationData   Json?
  failureChains  Json?                          // ★ 고장사슬 데이터 [{processNo, m4, fe, fm, fc, sod, ap, ...}]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  flatItems      PfmeaMasterFlatItem[]

  @@index([fmeaId])
  @@index([fmeaType])
  @@index([isActive])
  @@map("pfmea_master_datasets")
}

model PfmeaMasterFlatItem {
  id             String             @id @default(uuid())
  datasetId      String
  processNo      String
  category       String
  itemCode       String
  value          String
  m4             String?            // 4M 분류: MN(사람), MC(설비), IM(부자재), EN(환경)
  specialChar    String?            // 특별특성 기호: ◇, ◆, △, ○ 등
  inherited      Boolean            @default(false)  // ★ 상위에서 가져온 데이터
  sourceId       String?                              // ★ 원본 dataset ID
  createdAt      DateTime           @default(now())
  // ★★★ 2026-02-25: 위치/모자관계/병합 정보 ★★★
  excelRow       Int?               // 엑셀 원본 행 번호 (1-based)
  excelCol       Int?               // 엑셀 원본 열 번호 (1-based)
  orderIndex     Int?               // 같은 processNo+itemCode 내 순서 (0-based)
  parentItemId   String?            // 부모 아이템 ID (모자관계)
  mergeGroupId   String?            // 병합 그룹 ID
  rowSpan        Int?               // 병합 행 수 (1=단일, 2+=병합)
  belongsTo      String?            // 소속 작업요소 이름 (B2/B3)
  dataset        PfmeaMasterDataset @relation(fields: [datasetId], references: [id], onDelete: Cascade)

  @@unique([datasetId, processNo, itemCode, parentItemId, value])
  @@index([datasetId])
  @@index([parentItemId])
  @@index([mergeGroupId])
  @@map("pfmea_master_flat_items")
}

model FailureLink {
  id              String           @id @default(uuid())
  fmeaId          String
  fmId            String
  feId            String
  fcId            String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  fmText          String?
  fmProcess       String?
  feText          String?
  feScope         String?
  fcText          String?
  fcWorkElem      String?
  fcM4            String?
  severity        Int?
  fmSeq           Int?
  feSeq           Int?
  fcSeq           Int?
  fmPath          String?
  fePath          String?
  fcPath          String?
  parentId        String?
  mergeGroupId    String?
  rowSpan         Int?             @default(1)
  colSpan         Int?             @default(1)
  failureAnalyses FailureAnalysis?
  failureCause    FailureCause     @relation(fields: [fcId], references: [id], onDelete: Cascade)
  failureEffect   FailureEffect    @relation(fields: [feId], references: [id], onDelete: Cascade)
  failureMode     FailureMode      @relation(fields: [fmId], references: [id], onDelete: Cascade)
  riskAnalyses    RiskAnalysis[]
  deletedAt       DateTime?          // ★ soft delete 지원 (30일 후 자동 정리)

  @@index([fmeaId])
  @@index([fmId])
  @@index([feId])
  @@index([fcId])
  @@index([parentId])
  @@index([mergeGroupId])
  @@unique([fmeaId, fmId, feId, fcId])
  @@index([fmeaId, fmId, feId, fcId])
  @@map("failure_links")
}

model FailureAnalysis {
  id                String      @id @default(uuid())
  fmeaId            String
  linkId            String      @unique
  fmId              String
  fmText            String
  fmProcessName     String
  feId              String
  feText            String
  feCategory        String
  feSeverity        Int
  fcId              String
  fcText            String
  fcOccurrence      Int?
  fcWorkElementName String
  fcM4              String?
  l1FuncId          String
  l1Category        String
  l1FuncName        String
  l1Requirement     String
  l2FuncId          String
  l2FuncName        String
  l2ProductChar     String
  l2SpecialChar     String?
  l3FuncId          String
  l3FuncName        String
  l3ProcessChar     String
  l3SpecialChar     String?
  l1StructId        String
  l1StructName      String
  l2StructId        String
  l2StructNo        String
  l2StructName      String
  l3StructId        String
  l3StructM4        String?
  l3StructName      String
  order             Int         @default(0)
  confirmed         Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  failureLink       FailureLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([linkId])
  @@index([fmId])
  @@index([feId])
  @@index([fcId])
  @@map("failure_analyses")
}

model RiskAnalysis {
  id                String         @id @default(uuid())
  fmeaId            String
  linkId            String
  severity          Int
  occurrence        Int
  detection         Int
  ap                String
  preventionControl String?
  detectionControl  String?
  lldReference      String?
  dcSourceType      String?                        // 'manual' | 'master' | 'industry' | 'lld' | 'keyword'
  dcSourceId        String?                        // 소스 엔티티 UUID
  pcSourceType      String?                        // 'manual' | 'master' | 'industry' | 'lld'
  pcSourceId        String?                        // 소스 엔티티 UUID
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  optimizations     Optimization[]
  failureLink       FailureLink    @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([linkId])
  @@index([fmeaId, linkId])
  @@index([dcSourceType])
  @@index([pcSourceType])
  @@map("risk_analyses")
}

model Optimization {
  id                String       @id @default(uuid())
  fmeaId            String
  riskId            String
  recommendedAction String
  responsible       String
  targetDate        String
  newSeverity       Int?
  newOccurrence     Int?
  newDetection      Int?
  newAP             String?
  status            String
  completedDate     String?
  remarks           String?
  detectionAction   String?
  lldOptReference   String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  riskAnalysis      RiskAnalysis @relation(fields: [riskId], references: [id], onDelete: Cascade)

  @@index([fmeaId])
  @@index([riskId])
  @@map("optimizations")
}

model FmeaProject {
  id               String             @id @default(uuid())
  fmeaId           String             @unique
  fmeaType         String             @default("P")
  parentApqpNo     String?
  parentFmeaId     String?
  parentFmeaType   String?
  tripletGroupId   String?            // TripletGroup 연결
  status           String             @default("active")
  step             Int                @default(1)
  revisionNo       String             @default("Rev.00")
  revMajor         Int                @default(0)
  revMinor         Int                @default(0)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?
  cftMembers       FmeaCftMember[]
  registration     FmeaRegistration?
  worksheetData    FmeaWorksheetData?

  @@index([fmeaType])
  @@index([parentFmeaId])
  @@index([tripletGroupId])
  @@index([status])
  @@index([deletedAt])
  @@map("fmea_projects")
}

model FmeaRegistration {
  id                   String      @id @default(uuid())
  fmeaId               String      @unique
  companyName          String?
  engineeringLocation  String?
  customerName         String?
  modelYear            String?
  subject              String?
  fmeaStartDate        String?
  fmeaRevisionDate     String?
  fmeaProjectName      String?
  designResponsibility String?
  confidentialityLevel String?
  fmeaResponsibleName  String?
  partName             String?
  partNo               String?
  parentApqpNo         String?
  linkedCpNo           String?
  linkedCpNos          String?     // Family CP: JSON 배열 (모든 하위 CP IDs)
  linkedPfdNo          String?
  linkedDfmeaNo        String?
  linkedPfmeaNo        String?
  remark               String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  project              FmeaProject @relation(fields: [fmeaId], references: [fmeaId], onDelete: Cascade)

  @@index([fmeaId])
  @@map("fmea_registrations")
}

model FmeaCftMember {
  id             String      @id @default(uuid())
  fmeaId         String
  role           String?
  name           String?
  department     String?
  position       String?
  responsibility String?
  email          String?
  phone          String?
  remarks        String?
  order          Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
