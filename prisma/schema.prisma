  customerSymbol  String   @default("")           // 기호 (◇, ★ 등)
  meaning         String   @default("")           // 기준/설명
  color           String   @default("#f5f5f5")
  partName        String   @default("")           // 부품명
  processName     String   @default("")           // 공정명
  productChar     String   @default("")           // 제품특성
  processChar     String   @default("")           // 공정특성
  failureMode     String   @default("")           // 고장형태
  linkDFMEA       Boolean  @default(false)
  linkPFMEA       Boolean  @default(true)
  linkCP          Boolean  @default(true)
  linkPFD         Boolean  @default(false)
  usageCount      Int      @default(0)            // 사용 횟수 (추천 정렬)
  lastUsedAt      DateTime?                       // 마지막 사용일
