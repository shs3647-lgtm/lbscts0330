  description String // 상세 기준 설명
  detection   String? // 검출관리 예시
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([rating])
  @@map("pfmea_detection_criteria")
}

// DFMEA 심각도 기준
model DfmeaSeverityCriteria {
