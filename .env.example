# Database Configuration
# PostgreSQL 연결 문자열
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:your_password@localhost:5432/fmea_db?schema=public"

# Next.js Configuration
# API 기본 URL (개발: http://localhost:3000, 프로덕션: 실제 도메인)
NEXT_PUBLIC_API_URL=http://localhost:3000

# Application Environment
# development | production | test
NODE_ENV=development

# Optional: Test Database (for E2E testing)
TEST_DATABASE_URL="postgresql://postgres:your_password@localhost:5432/fmea_test?schema=public"

# Optional: Playwright Test Configuration
TEST_BASE_URL=http://localhost:3001

# Optional: Session Secret (for authentication)
# SESSION_SECRET=your-secret-key-here

# Optional: SMTP Configuration (for email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# Optional: File Upload Configuration
# MAX_FILE_SIZE=10485760  # 10MB in bytes
# UPLOAD_DIR=./uploads

# Optional: Logging
# LOG_LEVEL=info  # debug | info | warn | error
